{
    "$schema": "http://json-schema.org/draft-06/schema",
    "$id":"trossen_widowx_driver_crospi.json",
    "type":"object",
    "properties":{
        "is-trossen_widowx_driver_crospi" : {
            "description":"To indicate that the tasks will be executed using the trossen_widowx_driver_crospi driver when running on the real robot.",
            "type":"boolean",
            "const": true
          }
    },
    "required":["is-trossen_widowx_driver_crospi"],
    "additionalProperties": true,
    "dependencies":{
        "is-trossen_widowx_driver_crospi":{
          "required":["ip_address", "control_mode", "periodicity"],
          "properties":{
            "ip_address" : {
                    "description":"IP address of the robot using Ipv4 format.",
                    "type":"string",
                    "pattern": "^(25[0-5]|2[0-4][0-9]|1[0-9]{2}|[1-9]?[0-9])\\.(25[0-5]|2[0-4][0-9]|1[0-9]{2}|[1-9]?[0-9])\\.(25[0-5]|2[0-4][0-9]|1[0-9]{2}|[1-9]?[0-9])\\.(25[0-5]|2[0-4][0-9]|1[0-9]{2}|[1-9]?[0-9])$",
                    "default": "192.168.1.2"
            },
            "control_mode": {
                "description": "Control mode for the robot arm.",
                "type": "string",
                "enum": ["JOINT_POSITION", "JOINT_VELOCITY"]
            },
            "periodicity" : {
                "description":"Periodicity in which the integration will be performed in seconds. 1/periodicity is the update frequency in Hz.",
                "type":"number",
                "default": 0.005
            }
          }
        }
      }
}